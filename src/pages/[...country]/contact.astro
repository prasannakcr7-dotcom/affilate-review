---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	return [
		{ params: { country: undefined } }, // default/US
		{ params: { country: 'in' } },       // India
	];
}

const country = (Astro.params.country as 'us' | 'in') || 'us';
---

<BaseLayout
	title={country === 'in' ? "Contact Us | SecondLook India" : "Contact Us | SecondLook"}
	description="Get in touch with us for product suggestions, editorial corrections, or partnerships."
	country={country}
>
	<article class="contact-container">
		<header class="contact-header">
			<span class="sub">Get in Touch</span>
			<h1>Have a question? We’d love to help.</h1>
			<p class="lead">
				Whether you found an error in one of our comparison tables, have a suggestion for a product we should review next, or want to discuss a partnership, drop us a line.
			</p>
		</header>

		<section class="contact-section">
			<div class="contact-info">
				<p>We read every email we receive. To help us get back to you faster, please use the most appropriate email channel below:</p>

				<div class="email-channels">
					<div class="channel-card">
						<h3>Editorial & Corrections</h3>
						<p class="desc">Found a typo, incorrect spec, or outdated link in one of our reviews?</p>
						<a href="mailto:editorial@secondlook.com" class="email-link">editorial@secondlook.com</a>
					</div>

					<div class="channel-card">
						<h3>Product Suggestions</h3>
						<p class="desc">Know a product that is absolutely stellar and think we should test it?</p>
						<a href="mailto:suggestions@secondlook.com" class="email-link">suggestions@secondlook.com</a>
					</div>

					<div class="channel-card">
						<h3>General Queries</h3>
						<p class="desc">Anything else, including general feedback or advertising questions.</p>
						<a href="mailto:hello@secondlook.com" class="email-link">hello@secondlook.com</a>
					</div>
				</div>
			</div>
		</section>
	</article>
</BaseLayout>

<style>
	.contact-container {
		max-width: 960px;
		margin: 0 auto;
		padding: 1.5rem 1rem;
	}

	.contact-header {
		text-align: center;
		margin-bottom: 3.5rem;
		max-width: 680px;
		margin-inline: auto;
	}

	.contact-header .sub {
		color: var(--ar-accent);
		font-weight: 800;
		text-transform: uppercase;
		font-size: 0.82rem;
		letter-spacing: 0.05em;
	}

	.contact-header h1 {
		margin: 0.5rem 0 0.8rem;
		font-family: var(--ar-font-serif);
		font-size: clamp(2rem, 4vw, 2.75rem);
		line-height: 1.15;
		font-weight: 700;
	}

	.contact-header .lead {
		font-size: 1.15rem;
		line-height: 1.5;
		color: var(--ar-muted);
		margin: 0;
	}

	.contact-section {
		max-width: 600px;
		margin: 0 auto;
	}

	.contact-info p {
		font-size: 1.02rem;
		line-height: 1.5;
		color: var(--ar-muted);
		margin: 0 0 2rem;
		text-align: center;
	}

	.email-channels {
		display: grid;
		gap: 1.5rem;
	}

	.channel-card {
		background: var(--ar-card);
		border: 1px solid var(--ar-border);
		padding: 1.25rem 1.5rem;
		border-radius: 6px;
		text-align: center;
	}

	.channel-card h3 {
		margin: 0 0 0.35rem;
		font-size: 1.1rem;
		font-family: var(--ar-font-serif);
	}

	.channel-card .desc {
		margin: 0 0 0.85rem;
		font-size: 0.92rem;
		line-height: 1.4;
		color: var(--ar-muted);
	}

	.email-link {
		color: var(--ar-link);
		font-weight: 700;
		text-decoration: none;
		font-size: 0.95rem;
	}

	.email-link:hover {
		text-decoration: underline;
	}
</style>
